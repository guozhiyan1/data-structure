二叉树的深度
#法一：分治法 分治法简介：求一个规模为n的问题，先求左边规模大约为n/2的问题，再求右边规模大约为n/2的问题，然后合并左边，右边的解，从而求得最终解。具体可参考归并排序。类似递归
#max( 父结点左子树的最大深度, 父结点右子树的最大深度)+1
class Solution:
    def TreeDepth(self, pRoot: TreeNode):
        if not pRoot:
            return 0
        left=right=0
        if pRoot.left:
            left=self.TreeDepth(pRoot.left)
        if pRoot.right:
            right=self.TreeDepth(pRoot.right)
        return max([left,right])+1
#法二：广度遍历：层次遍历，每经历一层， count+=1
class Solution1:
    def TreeDepth(self , pRoot: TreeNode) -> int:
        # write code here
        if not pRoot:
            return 0
        d=[]
        d.append(pRoot)
        length=0
        while len(d)!=0:
            for i in range(len(d)):
                r=d.pop(0)
                if r.left:
                    d.append(r.left)
                if r.right:
                    d.append(r.right)
            length=length+1
        return length

